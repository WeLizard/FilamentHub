# Database
# Для локальной разработки используйте localhost
# Docker Compose автоматически переопределит на правильные имена сервисов
DATABASE_URL=postgresql+asyncpg://filamenthub:your_password@localhost:5432/filamenthub
DATABASE_ECHO=False  # Set to True for SQL query logging

# Redis
# Для локальной разработки используйте localhost
# Docker Compose автоматически переопределит на правильные имена сервисов
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# API
API_V1_PREFIX=/api/v1
PROJECT_NAME=FilamentHub
VERSION=0.1.0
DEBUG=True

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]

# File Upload
MAX_UPLOAD_SIZE_MB=50

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=100


