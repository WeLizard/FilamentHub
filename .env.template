# ============================================
# FilamentHub Production Configuration Template
# ============================================
# 
# ИНСТРУКЦИЯ:
# 1. Этот файл является шаблоном. Скопируйте его в .env и заполните значения.
# 2. НИКОГДА не коммитьте файл .env в git!
#
# ============================================

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Пароль для PostgreSQL (ОБЯЗАТЕЛЬНО измените для продакшена!)
POSTGRES_PASSWORD=filamenthub_prod_password

# Пользователь и база данных (можно оставить по умолчанию)
POSTGRES_USER=filamenthub
POSTGRES_DB=filamenthub
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_URL=redis://redis:6379/0

# ============================================
# SECURITY (КРИТИЧЕСКИ ВАЖНО!)
# ============================================
# Сгенерируйте случайный SECRET_KEY:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_TO_RANDOM_SECRET_KEY_MINIMUM_32_CHARACTERS

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================
# ADMIN USER CONFIGURATION
# ============================================
# Пароль для начального админ-пользователя
# После первого входа ОБЯЗАТЕЛЬНО смените пароль!
ADMIN_EMAIL=admin@filamenthub.local
ADMIN_PASSWORD=admin
ADMIN_USERNAME=admin

# Создавать ли админа автоматически при первом запуске?
CREATE_ADMIN_ON_STARTUP=True

# ============================================
# API CONFIGURATION
# ============================================
API_V1_PREFIX=/api/v1
PROJECT_NAME=FilamentHub
VERSION=0.1.0
DEBUG=False

# ============================================
# CORS CONFIGURATION
# ============================================
# Укажите домены вашего фронтенда. Для локального запуска оставьте как есть.
CORS_ORIGINS=["http://localhost","http://localhost:80","http://localhost:3000","http://localhost:5173","http://localhost:8080"]

# ============================================
# PORT MAPPING
# ============================================
# Порты, на которых будут доступны сервисы на вашем хосте
FRONTEND_PORT=80
BACKEND_PORT=8000
