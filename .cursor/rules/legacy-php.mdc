# tests/unit/test_orca_parser.py
import pytest
from app.services.gcode.orca_parser import OrcaSlicerParser

@pytest.fixture
def sample_gcode():
    """Пример G-code от OrcaSlicer."""
    return [
        "; generated by OrcaSlicer 2.0.0",
        "; filament_type = PLA",
        "; nozzle_diameter = 0.4",
        "; layer_height = 0.2",
        "; estimated printing time (normal mode) = 2h 35m 12s",
        "; filament used [mm] = 1234.56",
        "; filament used [g] = 120.5",
    ]

def test_detect_orcaslicer(sample_gcode):
    """Тест определения OrcaSlicer."""
    parser = OrcaSlicerParser()
    assert parser.detect(sample_gcode) is True

def test_parse_metadata(sample_gcode):
    """Тест парсинга метаданных."""
    parser = OrcaSlicerParser()
    metadata = parser.parse_metadata(sample_gcode)
    
    assert metadata['filament_type'] == 'PLA'
    assert metadata['nozzle_diameter'] == '0.4'
    assert metadata['layer_height'] == '0.2'

def test_parse_stats(sample_gcode):
    """Тест парсинга статистики."""
    parser = OrcaSlicerParser()
    stats = parser.parse_stats(sample_gcode)
    
    assert stats['print_time_seconds'] == 9312  # 2h 35m 12s
    assert stats['filament_used_g'] == 120.5

def test_parse_time():
    """Тест парсинга времени."""
    parser = OrcaSlicerParser()
    assert parser._parse_time("2h 35m 12s") == 9312
    assert parser._parse_time("1h 0m 0s") == 3600
    assert parser._parse_time("45m 30s") == 2730
```

