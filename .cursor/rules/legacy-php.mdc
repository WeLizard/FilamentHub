### Пример полного парсера:

```python
# backend/app/services/gcode/orca_parser.py
class OrcaSlicerParser(BaseGcodeParser):
    """Парсер для OrcaSlicer G-code."""
    
    slicer_name = "OrcaSlicer"
    
    def detect(self, lines: list[str]) -> bool:
        """Проверяет наличие идентификаторов OrcaSlicer."""
        for line in lines[:50]:  # проверяем первые 50 строк
            if "generated by OrcaSlicer" in line.lower():
                return True
            if "; orca" in line.lower():
                return True
        return False
    
    def parse_metadata(self, lines: list[str]) -> dict:
        """Извлечь метаданные из комментариев."""
        metadata = {
            'slicer': self.slicer_name,
            'filament_type': None,
            'filament_brand': None,
            'nozzle_diameter': None,
            'layer_height': None,
        }
        
        patterns = {
            'filament_type': r'; filament_type = (.+)',
            'nozzle_diameter': r'; nozzle_diameter = (.+)',
            'layer_height': r'; layer_height = (.+)',
        }
        
        for line in lines[:200]:  # метаданные обычно в начале
            for key, pattern in patterns.items():
                if match := re.match(pattern, line):
                    metadata[key] = match.group(1).strip()
        
        return metadata
    
    def parse_stats(self, lines: list[str]) -> dict:
        """Извлечь статистику печати."""
        stats = {
            'print_time_seconds': 0,
            'filament_used_mm': 0.0,
            'filament_used_g': 0.0,
            'estimated_cost': 0.0,
        }
        
        for line in lines:
            # Время печати
            if match := re.match(r'; estimated printing time.* = (.+)', line):
                stats['print_time_seconds'] = self._parse_time(match.group(1))
            
            # Использованный материал
            if match := re.match(r'; filament used \[mm\] = (.+)', line):
                stats['filament_used_mm'] = float(match.group(1))
            
            if match := re.match(r'; filament used \[g\] = (.+)', line):
                stats['filament_used_g'] = float(match.group(1))
        
        return stats
    
    def _parse_time(self, time_str: str) -> int:
        """
        Парсит время из строк вида '2h 35m 12s' в секунды.
        
        Args:
            time_str: Строка времени
            
        Returns:
            int: Время в секундах
        """
        total_seconds = 0
        
        # Парсим часы
        if match := re.search(r'(\d+)h', time_str):
            total_seconds += int(match.group(1)) * 3600
        
        # Парсим минуты
        if match := re.search(r'(\d+)m', time_str):
            total_seconds += int(match.group(1)) * 60
        
        # Парсим секунды
        if match := re.search(r'(\d+)s', time_str):
            total_seconds += int(match.group(1))
        
        return total_seconds
```

## 💰 Калькулятор стоимости

### PHP версия (reference):
```php
// 3dcalc/src/services/cost_calculator_service.php
function calculatePrintCost($weight_g, $print_time_h, $material_cost_per_kg, $electricity_cost) {
    $material_cost = ($weight_g / 1000) * $material_cost_per_kg;
    $electricity_cost_total = $print_time_h * $electricity_cost;
    return $material_cost + $electricity_cost_total;
}
```

### Python версия (новая):
```python
# backend/app/services/calculator.py
from dataclasses import dataclass
from typing import Optional

@dataclass
class PrintCostComponents:
    """Компоненты стоимости печати."""
    material_cost: float
    electricity_cost: float
    labor_cost: float
    printer_amortization: float
    total_cost: float

class CostCalculator:
    """Калькулятор стоимости 3D печати."""
    
    def __init__(
        self,
        electricity_rate: float = 5.5,  # руб/кВт·ч (Россия средняя)
        labor_rate: float = 0.0,  # руб/час (опционально)
        printer_cost: float = 0.0,  # стоимость принтера (для амортизации)
        printer_lifespan_hours: int = 10000,  # срок службы в часах
    ):
        self.electricity_rate = electricity_rate
        self.labor_rate = labor_rate
        self.printer_cost = printer_cost
        self.printer_lifespan_hours = printer_lifespan_hours
    
    def calculate_cost(
        self,
        weight_g: float,
        print_time_seconds: int,
        filament_price_per_kg: float,
        printer_power_kw: float = 0.2,  # средняя мощность FDM принтера
        include_labor: bool = False,
        include_amortization: bool = False,
    ) -> PrintCostComponents:
        """
        Рассчитать стоимость печати.
        
        Args:
            weight_g: Вес детали в граммах
            print_time_seconds: Время печати в секундах
            filament_price_per_kg: Цена филамента за кг (руб)
            printer_power_kw: Потребляемая мощность принтера (кВт)
            include_labor: Учитывать ли стоимость труда
            include_amortization: Учитывать ли амортизацию принтера
            
        Returns:
            PrintCostComponents: Компоненты стоимости
        """
        # Стоимость материала
        material_cost = (weight_g / 1000) * filament_price_per_kg
        
        # Стоимость электричества
        print_time_hours = print_time_seconds / 3600
        electricity_cost = print_time_hours * printer_power_kw * self.electricity_rate
        
        # Стоимость труда (опционально)
        labor_cost = 0.0
        if include_labor:
            labor_cost = print_time_hours * self.labor_rate
        
        # Амортизация принтера (опционально)
        amortization = 0.0
        if include_amortization and self.printer_cost > 0:
            cost_per_hour = self.printer_cost / self.printer_lifespan_hours
            amortization = print_time_hours * cost_per_hour
        
        # Общая стоимость
        total_cost = material_cost + electricity_cost + labor_cost + amortization
        
        return PrintCostComponents(
            material_cost=round(material_cost, 2),
            electricity_cost=round(electricity_cost, 2),
            labor_cost=round(labor_cost, 2),
            printer_amortization=round(amortization, 2),
            total_cost=round(total_cost, 2),
        )
    
    def calculate_from_gcode(
        self,
        gcode_file_path: str,
        filament_price_per_kg: float,
        **kwargs,
    ) -> tuple[PrintCostComponents, dict]:
        """
        Рассчитать стоимость из G-code файла.
        
        Args:
            gcode_file_path: Путь к G-code файлу
            filament_price_per_kg: Цена филамента
            **kwargs: Дополнительные параметры для calculate_cost
            
        Returns:
            tuple: (компоненты стоимости, метаданные)
        """
        # Читаем файл
        with open(gcode_file_path, 'r', encoding='utf-8') as f:
            lines = f.readlines()
        
        # Определяем парсер
        parser = self._detect_parser(lines)
        if not parser:
            raise ValueError("Не удалось определить слайсер")
        
        # Парсим метаданные и статистику
        metadata = parser.parse_metadata(lines)
        stats = parser.parse_stats(lines)
        
        # Рассчитываем стоимость
        cost = self.calculate_cost(
            weight_g=stats['filament_used_g'],
            print_time_seconds=stats['print_time_seconds'],
            filament_price_per_kg=filament_price_per_kg,
            **kwargs,
        )
        
        return cost, {**metadata, **stats}
    
    def _detect_parser(self, lines: list[str]) -> Optional[BaseGcodeParser]:
        """Определить подходящий парсер."""
        parsers = [
            OrcaSlicerParser(),
            PrusaSlicerParser(),
            CuraParser(),
            # ... другие
        ]
        
        for parser in parsers:
            if parser.detect(lines):
                return parser
        
        return None
```

