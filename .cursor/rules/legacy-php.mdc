class BaseGcodeParser(ABC):
    """Базовый класс для всех парсеров."""
    
    slicer_name: str = ""
    
    @abstractmethod
    def detect(self, lines: list[str]) -> bool:
        """Определить, что файл создан этим слайсером."""
