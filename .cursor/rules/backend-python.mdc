## 📦 FastAPI Patterns

### 1. Эндпоинты (API Routes)

```python
from fastapi import APIRouter, Depends, HTTPException, status, Query
from sqlalchemy.ext.asyncio import AsyncSession

from app.db.session import get_db
from app.schemas.filament import FilamentCreate, FilamentResponse, FilamentList
from app.services.filament import FilamentService
from app.core.dependencies import get_current_user

router = APIRouter(prefix="/filaments", tags=["filaments"])

@router.get("/", response_model=FilamentList)
async def list_filaments(
    skip: int = Query(0, ge=0, description="Пропустить N записей"),
    limit: int = Query(100, ge=1, le=100, description="Лимит записей"),
    material_type: str | None = Query(None, description="Фильтр по типу"),
    brand_id: int | None = Query(None, description="Фильтр по бренду"),
    db: AsyncSession = Depends(get_db),
) -> FilamentList:
    """
    Получить список материалов с фильтрацией и пагинацией.
    
    Args:
        skip: Сколько записей пропустить
        limit: Максимум записей в ответе
        material_type: Фильтр по типу материала (PLA, PETG, etc)
        brand_id: ID бренда для фильтрации
        db: Сессия БД
        
    Returns:
        FilamentList: Список материалов с пагинацией
    """
    service = FilamentService(db)
    filaments, total = await service.list_with_filters(
        skip=skip,
        limit=limit,
        material_type=material_type,
        brand_id=brand_id,
    )
    return FilamentList(items=filaments, total=total, skip=skip, limit=limit)

@router.post("/", response_model=FilamentResponse, status_code=status.HTTP_201_CREATED)
async def create_filament(
    filament_in: FilamentCreate,
    current_user: User = Depends(get_current_user),
    db: AsyncSession = Depends(get_db),
) -> FilamentResponse:
    """Создать новый материал (только для производителей)."""
    if current_user.role != "brand":
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail="Только производители могут добавлять материалы",
        )
    
    service = FilamentService(db)
    filament = await service.create(filament_in, brand_id=current_user.brand_id)
    return filament

@router.get("/{filament_id}", response_model=FilamentResponse)
async def get_filament(
    filament_id: int,
    db: AsyncSession = Depends(get_db),
) -> FilamentResponse:
    """Получить материал по ID."""
    service = FilamentService(db)
    filament = await service.get_by_id(filament_id)
    
    if not filament:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail=f"Материал с ID {filament_id} не найден",
        )
    
    return filament
```

### 2. SQLAlchemy Models (Async)

```python
from datetime import datetime
from typing import TYPE_CHECKING

from sqlalchemy import ForeignKey, Integer, String, Float, JSON, Boolean
from sqlalchemy.orm import Mapped, mapped_column, relationship

from app.db.base import Base

if TYPE_CHECKING:
    from app.models.brand import Brand
    from app.models.preset import Preset

class Filament(Base):
    """Модель материала для 3D печати."""
    
    __tablename__ = "filaments"

    # Primary Key
    id: Mapped[int] = mapped_column(Integer, primary_key=True, index=True)
    
    # Foreign Keys
    brand_id: Mapped[int] = mapped_column(ForeignKey("brands.id", ondelete="CASCADE"))
    
    # Basic Info
    name: Mapped[str] = mapped_column(String(255), nullable=False)
    material_type: Mapped[str] = mapped_column(String(64), index=True)  # PLA, PETG, etc
    color_hex: Mapped[str] = mapped_column(String(7))  # #FF0000
    
    # Physical Properties
    diameter: Mapped[float] = mapped_column(Float)  # 1.75 or 2.85 mm
    density: Mapped[float] = mapped_column(Float)  # г/см³
    weight: Mapped[float | None] = mapped_column(Float, nullable=True)  # грамм на катушке
    
    # Pricing
    price: Mapped[float | None] = mapped_column(Float, nullable=True)  # цена в рублях
    
    # Settings (JSON)
    settings: Mapped[dict] = mapped_column(JSON, default=dict)
    # Example: {
    #   "extruder_temp": 210,
    #   "bed_temp": 60,
    #   "print_speed": 60,
    #   "flow_rate": 1.0,
    # }
    
    # Timestamps
    created_at: Mapped[datetime] = mapped_column(default=datetime.utcnow)
    updated_at: Mapped[datetime] = mapped_column(
        default=datetime.utcnow,
        onupdate=datetime.utcnow,
    )
    
    # Relationships
    brand: Mapped["Brand"] = relationship(back_populates="filaments")
    presets: Mapped[list["Preset"]] = relationship(
        back_populates="filament",
        cascade="all, delete-orphan",
    )
    
    def __repr__(self) -> str:
        return f"<Filament(id={self.id}, name='{self.name}', type='{self.material_type}')>"
```

### 3. Pydantic Schemas

```python
from datetime import datetime
from pydantic import BaseModel, Field, field_validator, ConfigDict

# Base schema (общие поля)
class FilamentBase(BaseModel):
    """Базовая схема материала."""
    
    name: str = Field(..., min_length=1, max_length=255, description="Название материала")
    material_type: str = Field(
        ...,
        pattern="^(PLA|PETG|ABS|TPU|NYLON|ASA|PC|WOOD_PLA|CARBON|FLEX)$",
        description="Тип материала",
    )
    color_hex: str = Field(..., pattern="^#[0-9A-Fa-f]{6}$", description="Цвет в HEX")
    diameter: float = Field(..., ge=1.0, le=3.0, description="Диаметр нити в мм")
    density: float = Field(..., ge=0.5, le=2.0, description="Плотность в г/см³")
    weight: float | None = Field(None, ge=0, description="Вес нити на катушке (г)")
    price: float | None = Field(None, ge=0, description="Цена в рублях")
    settings: dict = Field(default_factory=dict, description="Настройки печати")
    
    @field_validator("settings")
    @classmethod
    def validate_settings(cls, v: dict) -> dict:
        """Валидация настроек."""
        if not v:
            return {}
        
        # Проверяем температуры
        if "extruder_temp" in v:
            temp = v["extruder_temp"]
            if not (150 <= temp <= 300):
                raise ValueError(f"Температура экструдера должна быть 150-300°C, получено: {temp}")
        
        if "bed_temp" in v:
            temp = v["bed_temp"]
            if not (0 <= temp <= 150):
                raise ValueError(f"Температура стола должна быть 0-150°C, получено: {temp}")
        
        return v

# Create schema (для создания)
class FilamentCreate(FilamentBase):
    """Схема для создания материала."""
    brand_id: int = Field(..., gt=0, description="ID производителя")

# Update schema (для обновления)
class FilamentUpdate(BaseModel):
    """Схема для обновления материала."""
    name: str | None = None
    color_hex: str | None = None
    price: float | None = None
    settings: dict | None = None

# Response schema (для ответа)
class FilamentResponse(FilamentBase):
    """Схема ответа с материалом."""
    id: int
    brand_id: int
    created_at: datetime
    updated_at: datetime
    
    model_config = ConfigDict(from_attributes=True)  # для SQLAlchemy 2.0

# List response
class FilamentList(BaseModel):
    """Список материалов с пагинацией."""
    items: list[FilamentResponse]
    total: int
    skip: int
    limit: int
```

### 4. Service Layer (Бизнес-логика)

```python
from sqlalchemy import select, func
from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy.orm import selectinload

from app.models.filament import Filament
from app.schemas.filament import FilamentCreate, FilamentUpdate

class FilamentService:
    """Сервис для работы с материалами."""
    
    def __init__(self, db: AsyncSession):
        self.db = db
    
    async def create(self, filament_in: FilamentCreate, brand_id: int) -> Filament:
        """Создать новый материал."""
        filament = Filament(**filament_in.model_dump(), brand_id=brand_id)
        self.db.add(filament)
        await self.db.commit()
        await self.db.refresh(filament)
        return filament
    
    async def get_by_id(self, filament_id: int) -> Filament | None:
        """Получить материал по ID."""
        result = await self.db.execute(
            select(Filament)
            .where(Filament.id == filament_id)
            .options(selectinload(Filament.brand))  # eager loading
        )
        return result.scalar_one_or_none()
    
    async def list_with_filters(
        self,
        skip: int = 0,
        limit: int = 100,
        material_type: str | None = None,
        brand_id: int | None = None,
    ) -> tuple[list[Filament], int]:
        """
        Получить список материалов с фильтрами.
        
        Returns:
            tuple: (список материалов, общее количество)
        """
        # Базовый запрос
        query = select(Filament).options(selectinload(Filament.brand))
        count_query = select(func.count(Filament.id))
        
        # Применяем фильтры
        if material_type:
            query = query.where(Filament.material_type == material_type)
            count_query = count_query.where(Filament.material_type == material_type)
        
        if brand_id:
            query = query.where(Filament.brand_id == brand_id)
            count_query = count_query.where(Filament.brand_id == brand_id)
        
        # Пагинация
        query = query.offset(skip).limit(limit)
        
        # Выполняем запросы
        result = await self.db.execute(query)
        count_result = await self.db.execute(count_query)
        
        filaments = list(result.scalars().all())
        total = count_result.scalar_one()
        
        return filaments, total
    
    async def update(
        self,
        filament_id: int,
        filament_update: FilamentUpdate,
    ) -> Filament | None:
        """Обновить материал."""
        filament = await self.get_by_id(filament_id)
        if not filament:
            return None
        
        # Обновляем только переданные поля
        update_data = filament_update.model_dump(exclude_unset=True)
        for field, value in update_data.items():
            setattr(filament, field, value)
        
        await self.db.commit()
        await self.db.refresh(filament)
        return filament
    
    async def delete(self, filament_id: int) -> bool:
        """Удалить материал."""
        filament = await self.get_by_id(filament_id)
        if not filament:
            return False
        
        await self.db.delete(filament)
        await self.db.commit()
        return True
```

## 🔒 Security & Auth

```python
from datetime import datetime, timedelta
from passlib.context import CryptContext
from jose import JWTError, jwt
from fastapi import Depends, HTTPException, status
from fastapi.security import OAuth2PasswordBearer

# Password hashing
pwd_context = CryptContext(schemes=["bcrypt"], deprecated="auto")

def hash_password(password: str) -> str:
    """Хешировать пароль."""
    return pwd_context.hash(password)

def verify_password(plain_password: str, hashed_password: str) -> bool:
    """Проверить пароль."""
    return pwd_context.verify(plain_password, hashed_password)

# JWT
SECRET_KEY = "your-secret-key-from-env"  # из .env!
ALGORITHM = "HS256"
ACCESS_TOKEN_EXPIRE_MINUTES = 15

def create_access_token(data: dict) -> str:
    """Создать JWT токен."""
    to_encode = data.copy()
    expire = datetime.utcnow() + timedelta(minutes=ACCESS_TOKEN_EXPIRE_MINUTES)
    to_encode.update({"exp": expire})
    return jwt.encode(to_encode, SECRET_KEY, algorithm=ALGORITHM)

# Dependency для получения текущего пользователя
oauth2_scheme = OAuth2PasswordBearer(tokenUrl="/api/v1/auth/login")

async def get_current_user(
    token: str = Depends(oauth2_scheme),
    db: AsyncSession = Depends(get_db),
) -> User:
    """Получить текущего пользователя из токена."""
    credentials_exception = HTTPException(
        status_code=status.HTTP_401_UNAUTHORIZED,
        detail="Невалидные credentials",
        headers={"WWW-Authenticate": "Bearer"},
    )
    
    try:
        payload = jwt.decode(token, SECRET_KEY, algorithms=[ALGORITHM])
        user_id: int = payload.get("sub")
        if user_id is None:
            raise credentials_exception
    except JWTError:
        raise credentials_exception
    
    # Получаем пользователя из БД
    user_service = UserService(db)
    user = await user_service.get_by_id(user_id)
    
    if user is None:
        raise credentials_exception
    
    return user
```

