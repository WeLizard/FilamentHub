@pytest.mark.asyncio
async def test_list_filaments_with_filter(
    client: AsyncClient,
    db: AsyncSession,
):
    """Тест фильтрации материалов."""
    response = await client.get(
        "/api/v1/filaments/",
        params={"material_type": "PLA", "limit": 10},
    )
    
    assert response.status_code == 200
    data = response.json()
    assert "items" in data
    assert "total" in data
    assert all(item["material_type"] == "PLA" for item in data["items"])
