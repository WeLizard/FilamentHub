## 📝 Style Guidelines

```typescript
// Naming
- PascalCase для компонентов: MyComponent.tsx
- camelCase для функций: handleClick
- SCREAMING_SNAKE_CASE для констант: API_BASE_URL

// Форматирование (Prettier)
- semi: true
- singleQuote: true
- Line length: 100

// TypeScript
- Используй interface для props (не type)
- Всегда типизируй useState, useRef
- Избегай any (используй unknown)
```

## 🎨 UI Components (shadcn/ui)

```typescript
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';

interface FilamentCardProps {
  filament: Filament;
  onSelect?: (id: number) => void;
}

export const FilamentCard: React.FC<FilamentCardProps> = ({ filament, onSelect }) => {
  return (
    <Card 
      className="cursor-pointer hover:shadow-lg transition-shadow"
      onClick={() => onSelect?.(filament.id)}
    >
      <CardHeader>
        <div className="flex items-center gap-2">
          <div 
            className="w-8 h-8 rounded-full"
            style={{ backgroundColor: filament.color_hex }}
          />
          <CardTitle>{filament.name}</CardTitle>
        </div>
      </CardHeader>
      <CardContent>
        <Badge>{filament.material_type}</Badge>
        <p className="text-sm text-muted-foreground">
          {filament.brand.name}
        </p>
      </CardContent>
    </Card>
  );
};
```

## 🔄 State Management (TanStack Query)

```typescript
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
import { api } from '@/services/api';

// GET запросы
export const useFilaments = (filters?: FilamentFilters) => {
  return useQuery({
    queryKey: ['filaments', filters],
    queryFn: () => api.get<FilamentList>('/api/v1/filaments/', { params: filters }),
    staleTime: 5 * 60 * 1000, // 5 минут
  });
};

// POST/PUT/DELETE запросы
export const useCreateFilament = () => {
  const queryClient = useQueryClient();
  
  return useMutation({
    mutationFn: (data: FilamentCreate) => 
      api.post<Filament>('/api/v1/filaments/', data),
    onSuccess: () => {
      // Инвалидируем кэш
      queryClient.invalidateQueries({ queryKey: ['filaments'] });
    },
  });
};
```

## 📝 Forms (React Hook Form + Zod)

```typescript
import { useForm } from 'react-hook-form';
import { zodResolver } from '@hookform/resolvers/zod';
import { z } from 'zod';

const filamentSchema = z.object({
  name: z.string().min(1, 'Название обязательно'),
  material_type: z.enum(['PLA', 'PETG', 'ABS', 'TPU', 'NYLON']),
  diameter: z.number().min(1).max(3),
  color_hex: z.string().regex(/^#[0-9A-Fa-f]{6}$/, 'Неверный формат цвета'),
});

type FilamentFormData = z.infer<typeof filamentSchema>;

export const FilamentForm: React.FC = () => {
  const form = useForm<FilamentFormData>({
    resolver: zodResolver(filamentSchema),
  });
  
  const { mutate: createFilament } = useCreateFilament();
  
  const onSubmit = (data: FilamentFormData) => {
    createFilament(data);
  };
  
  return (
    <Form {...form}>
      <form onSubmit={form.handleSubmit(onSubmit)}>
        {/* поля формы */}
      </form>
    </Form>
  );
};
```

---

**Это правило активируется когда начнем Frontend разработку.**
