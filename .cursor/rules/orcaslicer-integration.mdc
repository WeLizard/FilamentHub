## 📦 JSON Parsing

OrcaSlicer использует **nlohmann/json** (уже в проекте).

```cpp
#include <nlohmann/json.hpp>

using json = nlohmann::json;

void FilamentHubPanel::parse_filaments_response(const std::string& body)
{
    try {
        auto j = json::parse(body);
        
        // Clear existing items
        m_results_list->DeleteAllItems();
        
        // Parse items array
        for (const auto& item : j["items"]) {
            int idx = m_results_list->GetItemCount();
            
            std::string name = item["name"];
            std::string brand = item["brand"]["name"];
            std::string type = item["material_type"];
            
            m_results_list->InsertItem(idx, name);
            m_results_list->SetItem(idx, 1, brand);
            m_results_list->SetItem(idx, 2, type);
            
            // Store filament_id in item data
            m_results_list->SetItemData(idx, item["id"]);
        }
    } catch (json::exception& e) {
        show_error("Failed to parse response: " + std::string(e.what()));
    }
}
```

