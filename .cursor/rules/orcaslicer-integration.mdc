## 🔌 HTTP Client (libcurl)

OrcaSlicer уже использует libcurl для HTTP запросов.

### Пример GET запроса:
```cpp
#include "slic3r/Utils/Http.hpp"

namespace Slic3r {
namespace GUI {

void FilamentHubPanel::load_filaments(const std::string& query)
{
    std::string url = m_base_url + "/api/v1/filaments?search=" + query;
    
    auto http = Http::get(url);
    http.header("Authorization", "Bearer " + m_api_key);
    http.on_complete([this](std::string body, unsigned status) {
        if (status == 200) {
            // Parse JSON response
            parse_filaments_response(body);
        } else {
            show_error("Failed to load filaments");
        }
    });
    http.on_error([this](std::string body, std::string error, unsigned status) {
        show_error("Network error: " + error);
    });
    http.perform_sync();
}

} // namespace GUI
} // namespace Slic3r
```

