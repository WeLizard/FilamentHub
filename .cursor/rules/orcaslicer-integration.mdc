## 📁 Profile Management

Найти где хранятся профили и добавить свои:

```cpp
#include "slic3r/GUI/Preset.hpp"

void FilamentHubPanel::download_and_save_profile(int filament_id)
{
    // 1. Download profile JSON from API
    std::string url = m_base_url + "/api/v1/filaments/" + 
                      std::to_string(filament_id) + "/profile";
    
    auto http = Http::get(url);
    http.header("Authorization", "Bearer " + m_api_key);
    http.on_complete([this](std::string body, unsigned status) {
        if (status == 200) {
            save_profile_to_file(body);
        }
    });
    http.perform_sync();
}

void FilamentHubPanel::save_profile_to_file(const std::string& json_content)
{
    // 2. Parse JSON
    auto j = json::parse(json_content);
    
    // 3. Get filament preset dir
    auto preset_dir = wxGetApp().preset_bundle->filaments.get_preset_dir();
    
    // 4. Generate filename
    std::string filename = j["name"].get<std::string>() + " (FilamentHub).json";
    boost::filesystem::path profile_path = preset_dir / filename;
    
    // 5. Write file
    std::ofstream file(profile_path.string());
    file << json_content;
    file.close();
    
    // 6. Reload presets
    wxGetApp().preset_bundle->filaments.load_presets();
    
    show_message("Profile added successfully!");
}
```

