## 🎨 wxWidgets UI Basics

### Creating a Panel:
```cpp
FilamentHubPanel::FilamentHubPanel(wxWindow* parent)
    : wxPanel(parent, wxID_ANY)
{
    // Main sizer
    auto* main_sizer = new wxBoxSizer(wxVERTICAL);
    
    // Search box
    auto* search_sizer = new wxBoxSizer(wxHORIZONTAL);
    m_search_box = new wxTextCtrl(this, wxID_ANY, "", 
                                   wxDefaultPosition, wxDefaultSize);
    auto* search_btn = new wxButton(this, wxID_ANY, "Search");
    
    search_sizer->Add(m_search_box, 1, wxEXPAND | wxRIGHT, 5);
    search_sizer->Add(search_btn, 0);
    
    // Results list
    m_results_list = new wxListCtrl(this, wxID_ANY, 
                                     wxDefaultPosition, wxDefaultSize,
                                     wxLC_REPORT | wxLC_SINGLE_SEL);
    m_results_list->AppendColumn("Material", wxLIST_FORMAT_LEFT, 200);
    m_results_list->AppendColumn("Brand", wxLIST_FORMAT_LEFT, 150);
    m_results_list->AppendColumn("Type", wxLIST_FORMAT_LEFT, 80);
    
    // Apply button
    m_apply_button = new wxButton(this, wxID_ANY, "Add to Profiles");
    
    // Layout
    main_sizer->Add(search_sizer, 0, wxEXPAND | wxALL, 5);
    main_sizer->Add(m_results_list, 1, wxEXPAND | wxALL, 5);
    main_sizer->Add(m_apply_button, 0, wxALIGN_RIGHT | wxALL, 5);
    
    SetSizer(main_sizer);
    
    // Bind events
    search_btn->Bind(wxEVT_BUTTON, &FilamentHubPanel::on_search_clicked, this);
    m_apply_button->Bind(wxEVT_BUTTON, &FilamentHubPanel::on_apply_clicked, this);
}
```

